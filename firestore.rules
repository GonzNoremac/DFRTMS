// ============================================================
//  Firestore Security Rules — paste into Firebase Console
//  Firebase Console → Firestore → Rules tab
// ============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Only authenticated users can read or write anything
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

  }
}

// ============================================================
//  Notes:
//  - This allows any signed-in user full read/write access.
//  - Good for a small internal team where everyone is trusted.
//  - When you're ready to add role-based access (e.g. buyers
//    can only edit their own purchases, managers read-only),
//    we can expand these rules at that point.
// ============================================================
